model Admin{
  id             String @id @default(uuid())

  userId         String   @unique
  user           User   @relation(fields: [userId], references: [id],onDelete: Cascade, onUpdate: Cascade)

  name           String
  email          String
  profilePhoto   String?
  phone          String?
  gender         Gender?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("admin")
}